<!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.01 Transitional//EN" "http://www.w3.org/TR/html4/loose.dtd">
<html>
<head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
    <meta http-equiv="pragma" content="no-cache">
    <meta http-equiv="cache-control" content="no-cache, no-store,must-revalidate">
    <meta http-equiv="expires" content="0">
    <meta http-equiv="Content-Type" content="text/html;charset=UTF-8"/>
    <meta name="viewport" content="width=device-width,initial-scale=1,minimum-scale=0.5,maximum-scale=2.0,user-scalable=no">
    <link rel="stylesheet" href="../../../../material/custom/custom.css" type="text/css">
    <script type="text/javascript" src="../../../../material/custom/jquery-2.1.3.min.js"></script>
    <script type="text/javascript" src="../../../../material/custom/detectMobileBrowser.js"></script>
    <script type="text/javascript" src="../../../../material/custom/custom.js"></script>
    <script type="text/javascript" src="../../../../material/custom/auth.js"></script>
    <script type="text/javascript" src="../../../../material/custom/check.js"></script>
    <script>
        var _configId;
        var _isSocialPage;
        var _isMobilePage = false;
    </script>

    <script type="text/javascript" src="../../../../material/custom/lang/common-en.js"></script>
    <script type="text/javascript" src="../../../../material/custom/lang/auth-en.js"></script>

    <link rel="stylesheet" href="template.css" type="text/css">
    <title>WiFi UTP</title>

    <style>
        .logo-left img {
            background-color: rgba(255, 255, 255, 0.568);
            border-radius: 100%;
            z-index: 45;
            max-width: 100px;
        }

        body {
            font-family: Arial, sans-serif;
            height: inherit;
            background-color: #FFFFFF;
            background-image: url('fachada_utp.jpg'); 
            background-attachment: fixed;
            background-size: cover;
            margin: 0;
            padding: 0;
        }

        header {
            color: white;
            background-color: transparent;
            align-self: start;
            padding: 10px;
        }

        .login-container {
        background-color: rgba(255, 255, 255, 0.486);
        backdrop-filter: blur(7px);
        padding: 40px;
        border-radius: 10px;
        margin: 20px auto;
        max-width: 500px;
    }

    .welcome-text {
        text-align: center;
        font-size: 40px;
        font-weight: bold;
        margin-bottom: 40px;
        color: #333;
    }

    .login-table {
        width: 100%;
        margin: 0 auto;
    }

    .login-left {
        width: 50%;
        padding-right: 40px;
    }

    .login-right {
        width: 50%;
        padding-left: 40px;
        border-left: 1px solid #ddd;
    }

    .welcome-side-text {
        font-size: 24px;
        color: #333;
        margin-bottom: 20px;
    }

    .info-text {
        font-size: 14px;
        color: #666;
        line-height: 1.6;
        margin-bottom: 30px;
    }

    .frm-input {
        width: 100%;
        padding: 12px;
        margin-bottom: 20px;
        border: 1px solid #ddd;
        border-radius: 4px;
        font-size: 14px;
        height: 16px;
    }

    .button-group {
        margin-top: 30px;
    }

    .frm-button:hover {
        background-color: #02a08b;
    }
    .button-group {
        margin-top: 30px;
        display: flex;
        justify-content: center;
        gap: 20px;  
    }

    .frm-button {
        padding: 0 24px;  /* Ajuste horizontal solamente */
        height: 40px;     /* Altura fija */
        line-height: 40px; /* Igual a la altura para centrado vertical */
        -webkit-appearance: none; /* Eliminar estilos por defecto en navegadores WebKit */
        -moz-appearance: none;    /* Eliminar estilos por defecto en Firefox */
        appearance: none;         /* Eliminar estilos por defecto */
        border: none;
        border-radius: 4px;
        background-color: #681a5d;
        color: white;
        cursor: pointer;
        font-size: 14px;
        flex: 0 1 auto;
        white-space: nowrap;
    }

    .frm-button:hover {
        background-color: #02a08b;
    }

</style>
</head>
<body>
    <header>
        <div class="logo-left">
            <img src="tropical_utp_logo.jpg" alt="UTP Logo">
        </div>
    </header>

    <div class="login-container">
        <div class="welcome-text">Bienvenidos</div>
        
        <table class="login-table">
            <tr>
                <td class="login-left">
                    <div class="authmodel">
                        <div class="usernameContainer">
                            <input id="username" emptyTip="Username" type="text" class="frm-input" onkeydown="subOnkeydown()" placeholder="Usuario"/>
                        </div>
                        <input id="password" type="password" class="frm-input" onkeydown="subOnkeydown()" placeholder="Contraseña"/>
                        <div class="button-group">
                            <input id="loginBtn" type="button" value="Ingresar" class="frm-button" onclick="login()"/>
                            <!-- <input id="forgetPwd" type="button" value="Forget Password" class="frm-button" style="margin-left:20px" onclick="authTurnForgetPwdPage();"/> -->
                        </div>
                    </div>
                </td>
            </tr>
        </table>
    </div>
</body>
</html>